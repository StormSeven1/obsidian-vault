        <mxCell id="agent" value="雷达智能体子系统&#xa;• 任务接入&amp;#xa;• 智能研判&amp;#xa;• 流程编排&amp;#xa;• 工具代理&amp;#xa;• 记忆追溯" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0B2C69;strokeWidth=1.5;fontColor=#0B2C69;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="530" y="115" width="260" height="500" as="geometry"/></mxCell>
