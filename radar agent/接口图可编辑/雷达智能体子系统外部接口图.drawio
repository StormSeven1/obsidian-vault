        <mxCell id="display" value="显控分系统&#xa;• 显控任务提交&amp;#xa;• 任务状态查询&amp;#xa;• 研判结果展示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8F2;strokeColor=#E26012;strokeWidth=1.5;fontColor=#E26012;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="55" y="120" width="185" height="135" as="geometry"/></mxCell>
        <mxCell id="sense" value="信息处理感知子系统&#xa;• 检测识别跟踪&amp;#xa;• 定位与置信度&amp;#xa;• 异常评分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2FBFC;strokeColor=#00727A;strokeWidth=1.5;fontColor=#00727A;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="55" y="300" width="185" height="100" as="geometry"/></mxCell>
